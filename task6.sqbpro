(1,'2023-01-05',1200,101),
(2,'2023-01-10',800,102),
(3,'2023-01-15',1500,103),
(4,'2023-01-20',950,101),
(5,'2023-02-02',1100,104),
(6,'2023-02-08',700,102),
(7,'2023-02-14',1800,105),
(8,'2023-02-25',1300,103),
(9,'2023-03-03',900,101),
(10,'2023-03-09',1450,104),
(11,'2023-03-17',2100,105),
(12,'2023-03-28',1000,102);
SELECT 
strftime('%Y-%m', order_date) AS month,
SUM(amount) AS total_revenue,
COUNT(order_id) AS total_orders
FROM online_sales
GROUP BY month
ORDER BY month;</sql><current_tab id="0"/></tab_sql></sqlb_project>
